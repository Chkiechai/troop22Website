---
import BaseLayout from '../layouts/BaseLayout.astro';
const pageTitle = "JOIN US";
---
<BaseLayout pageTitle={pageTitle}>
  <h6>HOW TO JOIN ——— </h6>
  <h3 class="signal-header-cursive">Are you ready to start your journey with us?</h3>

  <p>Troop 22 welcomes girls of all experience levels. Whether you've never camped or 
    are working toward Eagle Scout, there's a place for you here. Parents are also welcome to join us as leaders! Our troop meets regularly and 
    always has something exciting planned.</p>

    <p>⬡ Open to girls of grades 6-12 (ages 11-17)</p>
    <p>⬡ No prior Scouting experience required</p>
    <p>⬡ Meetings held weekly in Cape Girardeau</p>
    <p>⬡ Active, supportive troop community</p>
    <p>⬡ Path to Eagle Scout rank available</p>


</BaseLayout>